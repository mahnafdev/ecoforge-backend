model Idea {
    id         String @id @default(cuid())
    authorId   String
    categoryId String

    title             String     @db.VarChar(100)
    problem           String
    solution          String
    description       String
    thumbnail         String?
    status            IdeaStatus @default(DRAFT)
    isPaid            Boolean    @default(false)
    price             Decimal?   @db.Decimal(8, 2)
    rejectionFeedback String?    @db.VarChar(256)
    upvoteCount       Int        @default(0)
    downvoteCount     Int        @default(0)

    isDeleted Boolean @default(false)

    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt
    deletedAt   DateTime?
    publishedAt DateTime?

    author   User      @relation(fields: [authorId], references: [id])
    category Category  @relation(fields: [categoryId], references: [id])
    votes    Vote[]
    comments Comment[]
    payments Payment[]

    @@index([authorId], name: "idx_idea_authorId")
    @@index([categoryId], name: "idx_idea_categoryId")
    @@index([status, createdAt(sort: Desc)], name: "idx_idea_status_createdAt")
    @@index([isDeleted], name: "idx_idea_isDeleted")
    @@map("ideas")
}
