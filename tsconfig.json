{
	"compilerOptions": {
		"rootDir": ".",
		"outDir": "./dist",
		"module": "esnext",
		"target": "esnext",
		"types": ["node", "express"],
		"allowJs": true,
		"strict": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src", "prisma.config.ts", "tsup.config.ts"],
	"exclude": ["node_modules", "dist"]
}
